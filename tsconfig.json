{
  "compilerOptions": {
    /* Language */
    "target": "ES2020",

    /* Modules */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Project structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Node compatibility */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Safety */
    "strict": true,
    "skipLibCheck": true,

    /* Output */
    "sourceMap": true,

    /* Performance */
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}